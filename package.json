{
  "name": "epos",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "watch": "nodemon --exec yarn serve:electron",
    "start": "yarn nightly:rename && concurrently -k \"yarn serve:front\" \"yarn watch\"",
    "front:setup": "cd app && yarn",
    "electron:setup": "yarn",
    "setup": "yarn front:setup && yarn electron:setup",
    "serve:front": "cd app && yarn dev",
    "serve:electron": "set APP_IS_NIGHTLY=yes && set APP_IS_DEV=yes && yarn build && wait-on tcp:3000 && electron .",
    "build:front": "cd app && yarn build",
    "electron:build": "yarn build",
    "electron:builder": "electron-builder",
    "app:build": "yarn prod:rename && yarn build:front && yarn electron:build && yarn electron:builder",
    "app:build:nightly": "set APP_IS_NIGHTLY=yes && set APP_IS_DEV=no && yarn nightly:rename && yarn build:front && yarn electron:build && yarn electron:builder",
    "nightly:rename": "json -I -f package.json -e \"this.name='epos'\" && json -I -f package.json -e \"this.build.productName='Epos Nightly'\" && json -I -f package.json -e \"this.build.appId='com.official-epos.app'\"",
    "prod:rename": "json -I -f package.json -e \"this.name='epos'\" && json -I -f package.json -e \"this.build.productName='Epos'\" && json -I -f package.json -e \"this.build.appId='com.official-epos.app'\"",
    "electron-rebuild": "./node_modules/.bin/electron-rebuild",
    "sqlite-rebuild": "cd node_modules/better-sqlite3 && yarnbuild-release",
    "postinstall": "electron-builder install-app-deps",
    "up:win": "up_using_window.cmd"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/cxrum/epistemic-oop.git"
  },
  "author": "cxrum",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/cxrum/epistemic-oop/issues"
  },
  "homepage": "https://github.com/cxrum/epistemic-oop#readme",
  "description": "",
  "build": {
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true
    },
    "files": [
      "package.json",
      "dist/**/*",
      "app/dist/**/*"
    ],
    "directories": {
      "app": ".",
      "buildResources": "electron/icons",
      "output": "build/release"
    },
    "extraResources": [
      {
        "from": "electron/icons/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "windows/icon.ico"
    },
    "mac": {
      "icon": "macos/icon.icns"
    },
    "linux": {
      "icon": "linux/icons"
    },
    "productName": "Epos Nightly",
    "appId": "com.official-epos.app"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^4.0.0",
    "json": "^11.0.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3"
  }
}
